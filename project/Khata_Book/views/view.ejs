<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="View record in Khata Book">
    <meta name="author" content="Your Name">
    <title>View Record | Khata Book</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div class="container">
        <header>
            <h1><span class="emoji">📔</span> Khata Book</h1>
            <p><span class="emoji">✨</span> Your Personal Ledger & Daily Records <span class="emoji">✨</span></p>
        </header>

        <div class="hero">
            <h2><span class="emoji">👁️</span> View Record</h2>
            <p><span class="emoji">📖</span> Review your complete record details</p>
        </div>

        <div class="card">
            <div class="card-header">
                <span class="card-date">📅 <%= single.date %></span>
            </div>
            <div class="card-text" style="margin: 24px 0; font-size: 1.1rem; line-height: 2;">
                <%= single.txt %>
            </div>
            <div class="card-actions">
                <form action="/edit/<%= single.id%>" method="POST">
                    <button type="submit" class="btn btn-primary">✏️ Edit</button>
                </form>
                <form action="/delete/<%= single.id%>" method="POST">
                    <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this record?')">🗑️ Delete</button>
                </form>
            </div>
            <a href="/" class="btn btn-secondary" style="width: 100%; padding: 14px; margin-top: 16px; font-size: 1rem;">← Back to Records</a>
        </div>

        <footer>
            <p>Made with ❤️ by Khata Book | v2.1</p>
        </footer>
    </div>
</body>
</html>