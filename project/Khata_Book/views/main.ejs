<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Khata Book - Your Personal Ledger">
    <meta name="author" content="Your Name">
    <title>Khata Book | Personal Ledger</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div class="container">
        <header>
            <h1><span class="emoji">📔</span> Khata Book</h1>
            <p><span class="emoji">✨</span> Your Personal Ledger & Daily Records <span class="emoji">✨</span></p>
        </header>

        <div class="stats">
            <div class="stat-card">
                <div class="stat-number"><%= data.length %></div>
                <div class="stat-label">📚 Records</div>
            </div>
        </div>

        <div class="text-center mb-30">
            <a href="/create" class="nav-link">➕ Create New Record</a>
        </div>

        <% if(data.length === 0) { %>
            <div class="empty-state">
                <div class="empty-state-icon">📝</div>
                <h2>No Records Yet</h2>
                <p>Start creating your first record to get started with Khata Book!</p>
                <a href="/create" class="nav-link">📝 Create First Record</a>
            </div>
        <% } else { %>
            <% for(var i=data.length-1; i>=0; i--){ %>
                <div class="card">
                    <div class="card-header">
                        <span class="card-date">📅 <%= data[i].date %></span>
                    </div>
                    <p class="card-text"><%= data[i].txt %></p>
                    <div class="card-actions">
                        <form action="/view/<%= data[i].id%>" method="GET">
                            <button type="submit" class="btn btn-info">👁️ View</button>
                        </form>
                        <form action="/edit/<%= data[i].id%>" method="POST">
                            <button type="submit" class="btn btn-primary">✏️ Edit</button>
                        </form>
                        <form action="/delete/<%= data[i].id%>" method="POST">
                            <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this record?')">🗑️ Delete</button>
                        </form>
                    </div>
                </div>
            <%}%>
        <% } %>

        <footer>
            <p>Made with ❤️ by Khata Book | v2.1</p>
        </footer>
    </div>
</body>
</html>